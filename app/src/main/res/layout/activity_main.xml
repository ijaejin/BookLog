<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/booklog_bg"
    tools:context=".MainActivity">

    <!-- 제목 -->

    <!-- 도서 검색 -->


    <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="400dp"
        android:layout_height="300dp"
        android:layout_marginTop="130dp"
        android:layout_marginBottom="30dp"
        android:src="@drawable/logo5_booklog"
        app:layout_constraintBottom_toTopOf="@+id/btnGoSearch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnGoSearch"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="도서 검색"
        app:layout_constraintTop_toBottomOf="@id/logoImageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/booklog_brown" />

    <!-- 내 서재 -->
    <Button
        android:id="@+id/btnMyLibrary"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="내 서재"
        app:layout_constraintTop_toBottomOf="@id/btnGoSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/booklog_brown"/>

    <!-- 게시판 -->
    <Button
        android:id="@+id/btnBoard"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="게시판"
        app:layout_constraintTop_toBottomOf="@id/btnMyLibrary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/booklog_brown"/>

    <!-- 설정 -->
    <Button
        android:id="@+id/btnSettings"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="설정"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBoard"
        app:layout_constraintVertical_bias="0.053"
        app:backgroundTint="@color/booklog_brown"/>

</androidx.constraintlayout.widget.ConstraintLayout>